# ============================================================
# AI Mock Interview Platform — Server Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- MongoDB ---
# Local:  mongodb://localhost:27017/ai_mock_interview
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/ai_mock_interview
MONGO_URI=mongodb://localhost:27017/ai_mock_interview

# --- JWT ---
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# --- CORS ---
CLIENT_URL=http://localhost:5173
